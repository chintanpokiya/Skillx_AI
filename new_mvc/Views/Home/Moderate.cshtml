@{
    ViewData["Title"] = "Post Analyzer";
}

<style>
    body {
        background: linear-gradient(135deg, #e0e7ff, #fbcfe8);
        font-family: 'Segoe UI', sans-serif;
    }

    .page {
        max-width: 720px;
        margin: 60px auto;
        padding: 32px;
        background: #ffffff;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .title {
        text-align: center;
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 20px;
        color: #1f2937;
    }

    .input-box {
        width: 100%;
        min-height: 110px;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid #d1d5db;
        outline: none;
        resize: vertical;
        transition: 0.2s;
    }

    .input-box:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.2);
    }

    .btn-submit {
        width: 100%;
        margin-top: 15px;
        padding: 12px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #6366f1, #ec4899);
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-submit:hover {
        transform: scale(1.03);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }

    .result {
        margin-top: 25px;
        display: none;
    }

    .success {
        padding: 12px;
        border-radius: 10px;
        background: #22c55e;
        color: white;
        font-weight: 600;
        text-align: center;
    }

    .error {
        padding: 12px;
        border-radius: 10px;
        background: #ef4444;
        color: white;
        font-weight: 600;
        text-align: center;
    }

    .category {
        margin-top: 20px;
    }

    .category-item {
        display: flex;
        justify-content: space-between;
        font-size: 14px;
        margin-bottom: 5px;
    }

    .bar {
        height: 10px;
        border-radius: 10px;
        background: #e5e7eb;
        overflow: hidden;
        margin-bottom: 12px;
    }

    .bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #ff4d4d, #ff0000);
        transition: width 0.5s ease;
    }
</style>

<div class="page">
    <div class="title">Post Analyzer & Publisher</div>

    <textarea id="txtInput" class="input-box" placeholder="Write your post here..."></textarea>

    <button id="btnSubmit" class="btn-submit">Submit Post</button>

    <div id="resultSection" class="result">
        <div id="statusMessage"></div>
        <div id="categoryList"></div>
    </div>
</div>

@section Scripts{
<script>
$(document).ready(function () {

    $("#btnSubmit").click(function () {

        const text = $("#txtInput").val().trim();

        if (!text) {
            alert("Please enter text");
            return;
        }

        $("#resultSection").hide();

        $.ajax({
            url: "/Home/Post/",
            type: "POST",
            data : {text : text},
            success: function (res) {

                $("#resultSection").fadeIn(300);

                if (res.success) {

                    $("#statusMessage")
                        .removeClass()
                        .addClass("success")
                        .text("✅ Your post has been successfully published!");

                    $("#categoryList").html("");

                } else {

                    $("#statusMessage")
                        .removeClass()
                        .addClass("error")
                        .text("⚠️ Post contains inappropriate content");

                    let html = "";

                    for (let key in res.moderation) {
                        let val = res.moderation[key];

                        html += `
                            <div class="category">
                                <div class="category-item">
                                    <span>${key}</span>
                                    <span>${(val * 100).toFixed(1)}%</span>
                                </div>
                                <div class="bar">
                                    <div class="bar-fill" style="width:${val * 100}%"></div>
                                </div>
                            </div>
                        `;
                    }

                    $("#categoryList").html(html);
                }
            },
            error: function () {
                alert("Server error");
            }
        });
    });

});
</script>
}