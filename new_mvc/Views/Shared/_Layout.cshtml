<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - new_mvc</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/new_mvc.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css"/>

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">new_mvc</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Recommendation">Recommendation</a>
                        </li>
                         <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Register">Register</a>
                        </li>
                         <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Post">Post</a>
                        </li>
                         <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="AllPosts">AllPosts</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer">
    <div class="container">
        <div>
            <a class="footer-brand" asp-controller="Home" asp-action="Index">TechFlow</a>
            <span class="footer-copy">&copy; 2026 — <a asp-controller="Home" asp-action="Privacy">Privacy</a></span>
        </div>
        <div class="footer-links">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a asp-controller="Home" asp-action="Register">Register</a>
            <a asp-controller="Home" asp-action="Login">Login</a>
            <a asp-controller="Home" asp-action="Recommendation">Recommendations</a>
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
        <div class="footer-badges">
            <span class="footer-badge cyan">ASP.NET Core</span>
            <span class="footer-badge blue">Kendo UI</span>
            <span class="footer-badge">AI Powered</span>
        </div>
    </div>
</footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
<div class="tech-particles">
    <span>{ }</span>
    <span>&lt;/&gt;</span>
    <span>{ }</span>
    <span>[]</span>
    <span>&lt;&gt;</span>
    <span>=&gt;</span>
    <span>{ }</span>
    <span>/&gt;</span>
    <span>( )</span>
    <span>&lt;/&gt;</span>

    <span>*</span>
    <span>~</span>
    <span>#</span>
    <span>{}</span>
    <span>()</span>
    <span>&lt;&gt;</span>
    <span>=</span>
    <span>+</span>
    <span>-</span>
    <span>^</span>
</div>
</html>
